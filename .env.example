# maestro configuration. Copy to .env and fill in. Only ANTHROPIC_API_KEY is required to run live.

# --- model ---
ANTHROPIC_API_KEY=sk-ant-...
MAESTRO_PROVIDER=anthropic            # anthropic | mock
MAESTRO_MODEL=claude-sonnet-4-6
MAESTRO_PERMISSION_MODE=auto          # auto | readonly (no write/exec/network) | safe (no high-risk)

# --- observability ---
MAESTRO_LOG_LEVEL=info                # fatal|error|warn|info|debug|trace|silent
MAESTRO_LOG_PRETTY=1                  # 1 = human-readable, 0 = JSON lines
MAESTRO_TRACES_DIR=.maestro/traces

# --- budgets (per run) ---
MAESTRO_MAX_STEPS=60
MAESTRO_MAX_TOKENS=400000
MAESTRO_MAX_WALLCLOCK_MS=900000

# --- context management ---
MAESTRO_MAX_CONTEXT_TOKENS=150000
MAESTRO_COMPACTION_THRESHOLD=0.7
MAESTRO_RECENCY_KEEP=8

# --- rate limits (requests/sec to external services) ---
MAESTRO_RL_ANTHROPIC=4
MAESTRO_RL_GITHUB=2
MAESTRO_RL_WEB=3
